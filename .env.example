FIN_DOC_LLM_CHAT_MODEL=llama3.2:3b
FIN_DOC_LLM_EMBED_MODEL=nomic-embed-text
FIN_DOC_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# Optional Gemini API profile
# Use the key from Google AI Studio. GOOGLE_API_KEY and GEMINI_API_KEY are aliases here;
# set only one of them in your private .env file, not in this example file.
GOOGLE_API_KEY=
# GEMINI_API_KEY=

# Optional LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=Finance Docs Insights

# Backward-compatible LangChain tracing variable names used by some LangChain setups
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
